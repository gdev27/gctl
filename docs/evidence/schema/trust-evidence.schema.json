{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gctl.dev/schemas/trust-evidence.schema.json",
  "title": "gctl Trust Evidence Bundle",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "source",
    "policy",
    "ens",
    "workflows",
    "attestation"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^1\\.0\\.0$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "enum": ["live", "fallback", "mixed"]
    },
    "policy": {
      "type": "object",
      "required": ["policyId", "version", "hash", "uri", "active"],
      "additionalProperties": false,
      "properties": {
        "policyId": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "hash": { "type": "string", "minLength": 8 },
        "uri": { "type": "string", "minLength": 3 },
        "active": { "type": "boolean" }
      }
    },
    "ens": {
      "type": "object",
      "required": ["fund", "roleIdentities"],
      "additionalProperties": false,
      "properties": {
        "fund": {
          "type": "object",
          "required": ["fundEnsName"],
          "additionalProperties": false,
          "properties": {
            "fundEnsName": { "type": "string", "pattern": "\\.eth$" }
          }
        },
        "roleIdentities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["ensName", "role", "capabilities", "verifiedReverse"],
            "additionalProperties": false,
            "properties": {
              "ensName": { "type": "string", "pattern": "\\.eth$" },
              "role": { "type": "string", "minLength": 1 },
              "capabilities": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "verifiedReverse": { "type": "boolean" }
            }
          }
        }
      }
    },
    "workflows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "workflowId",
          "runId",
          "state",
          "pathType",
          "auditPath",
          "logRef",
          "analyticsRef"
        ],
        "additionalProperties": false,
        "properties": {
          "workflowId": { "type": "string", "minLength": 1 },
          "runId": { "type": "string", "minLength": 1 },
          "state": {
            "type": "string",
            "enum": [
              "succeeded",
              "reverted",
              "partial_fill",
              "timed_out",
              "cancelled",
              "running",
              "denied"
            ]
          },
          "pathType": {
            "type": "string",
            "enum": ["safe", "escalated", "blocked"]
          },
          "auditPath": { "type": "string", "minLength": 1 },
          "logRef": { "type": "string", "minLength": 1 },
          "analyticsRef": { "type": "string", "minLength": 1 }
        }
      }
    },
    "attestation": {
      "type": "object",
      "required": ["kind", "receipt", "mappedRunIds"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["onchain", "simulated"]
        },
        "txHash": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{64}$"
        },
        "receipt": {
          "type": "string",
          "minLength": 1
        },
        "mappedRunIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "kind": { "const": "onchain" } }
          },
          "then": {
            "required": ["txHash"]
          }
        }
      ]
    },
    "invariantsCovered": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^INV-[A-Z]+-[0-9]{3}$"
      }
    }
  }
}
