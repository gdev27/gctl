{
  "name": "gctl",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22 <23"
  },
  "description": "gctl for policy-constrained autonomous agents.",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:zerog-sdk-legacy-smoke": "vitest run test/zeroGStorageSdkCompatibility.test.ts",
    "test:integration": "vitest run test/integration",
    "test:watch": "vitest",
    "verify": "npm run hh:compile && npm run test && npm run typecheck && npm run validate:env && npm run validate:evidence",
    "validate:env": "tsx scripts/validateEnvContracts.ts",
    "validate:evidence": "tsx scripts/validateEvidence.ts",
    "judge:preflight": "tsx scripts/judgePreflight.ts",
    "clean:runtime": "tsx scripts/cleanRuntime.ts",
    "clean:all-local": "tsx scripts/cleanAllLocal.ts",
    "compile:policy": "tsx scripts/compilePolicy.ts",
    "demo:init": "tsx scripts/initDemo.ts",
    "demo:small": "tsx scripts/demoSmallTrade.ts",
    "demo:large": "tsx scripts/demoLargeTrade.ts",
    "demo:deterministic": "tsx scripts/demoDeterministic.ts",
    "demo:swarm": "tsx agent-sdk/examples/treasuryTwinSwarm.ts",
    "ens:passport": "tsx ens-identity/scripts/showIdentityPassport.ts",
    "demo:all": "tsx scripts/initDemo.ts && tsx scripts/demoSmallTrade.ts && tsx scripts/demoLargeTrade.ts",
    "hh:compile": "hardhat compile",
    "hh:test": "hardhat test",
    "indexer:api": "tsx indexer/src/api.ts",
    "indexer:docker:build": "docker build -f Dockerfile.indexer -t gctl-indexer .",
    "indexer:docker:run": "docker run --rm -p 8080:8080 -e PORT=8080 gctl-indexer",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build",
    "web:typecheck": "npm --prefix web run typecheck",
    "web:lint": "npm --prefix web run lint",
    "ui:sweep:prod": "node scripts/ui-sweep-prod.mjs"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "dotenv": "^17.4.2",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@nomicfoundation/hardhat-ethers": "^4.0.9",
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.4",
    "@openzeppelin/contracts": "^5.6.1",
    "@types/chai": "^5.2.3",
    "@types/express": "^5.0.6",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "hardhat": "^3.4.1",
    "playwright": "^1.50.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
