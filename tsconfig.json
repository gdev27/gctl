{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node", "vitest/globals", "mocha", "chai"]
  },
  "include": [
    "types/**/*.d.ts",
    "hardhat.config.ts",
    "contracts/**/*.sol",
    "scripts/**/*.ts",
    "dsl/**/*.ts",
    "policy-engine/**/*.ts",
    "agent-sdk/**/*.ts",
    "ens-identity/**/*.ts",
    "keeperhub-workflows/**/*.ts",
    "indexer/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": ["test/PolicyRegistry.test.ts"]
}
