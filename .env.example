# Chain RPCs
MAINNET_RPC_URL=
# Base Sepolia public RPC (official)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Signers
DEPLOYER_PRIVATE_KEY=
AGENT_PRIVATE_KEY=

# Contracts
POLICY_REGISTRY_ADDRESS=
ERC8004_REGISTRY_ADDRESS=

# ENS
# Ethereum mainnet JSON-RPC (for ENS resolution / passport). Use any provider you trust.
ENS_MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com
FUND_ENS_NAME=eurofund.eth
AGENT_ENS_NAME=algo1.eurofund.eth
ENS_EXECUTION_PROFILE=standard
POLICY_REGISTRY_CHAIN_ID=84532
DEMO_TIMESTAMP=2026-01-01T00:00:00.000Z

# KeeperHub (base URL from KeeperHub; API key from dashboard — never commit real keys)
KEEPERHUB_API_URL=https://app.keeperhub.com
KEEPERHUB_API_KEY=
KEEPERHUB_USE_MOCK=true
KEEPERHUB_MOCK_FINAL_STATE=succeeded

# Reconciliation and logs
RECONCILIATION_LOG_DIR=./reconciliation-logs
AUDIT_LOG_ENCRYPTION_KEY=replace_with_32_byte_string

# Policy storage
POLICY_STORAGE_DIR=./policy-storage

# 0G integration — project-specific; use values from 0G docs, dashboard, or node config.
# Live 0G storage upload/download uses optional runtime package @0gfoundation/0g-storage-ts-sdk.
ZEROG_CHAIN_ID=16602
ZEROG_CHAIN_RPC_URL=https://evmrpc-testnet.0g.ai
ZEROG_STORAGE_ENDPOINT=
ZEROG_STORAGE_DOWNLOAD_URL=
ZEROG_STORAGE_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
ZEROG_STORAGE_RPC_URL=https://evmrpc-testnet.0g.ai
ZEROG_STORAGE_PRIVATE_KEY=
ZEROG_MEMORY_ENCRYPTION_KEY=replace_with_32_byte_hex_or_base64_key
ZEROG_COMPUTE_ENDPOINT=
ZEROG_COMPUTE_MODEL=qwen3.6-plus
ZEROG_MEMORY_DIR=./.zerog-memory
ZEROG_ATTESTATION_MODE=simulated
ZEROG_ATTESTATION_CONTRACT_ADDRESS=
ZEROG_ATTESTATION_PRIVATE_KEY=

# Ops UI / Vercel Functions — public HTTPS base for indexer/src/api.ts (never localhost in production).
# Policy list path is GET /fund/${FUND_ENS_NAME}/policies (see FUND_ENS_NAME under ENS above).
INDEXER_URL=
# Optional: absolute path to index-state.json when running the indexer in Docker / Fly with a volume.
INDEXER_STATE_PATH=

# Indexer HTTP bind (local defaults: host 0.0.0.0, port from INDEXER_PORT or 4300). PaaS usually sets PORT.
INDEXER_HOST=0.0.0.0
INDEXER_PORT=4300

# Swarm demo
SWARM_DEMO_AMOUNT=125000
